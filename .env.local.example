# OpenAI 兼容端口 — 用任何兼容协议的提供方（OpenAI 官方、Ollama、LM Studio、vLLM、DeepSeek、Moonshot...）
# 本地 Ollama:  OPENAI_BASE_URL=http://localhost:11434/v1
# 本地 LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1
# OpenAI 官方:  OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b-instruct

# 可选：决策调用的最大 token 数（被截断会报 finish=length）
TUTU_MAX_TOKENS=800

# 可选：Qwen3 等带思考模式的模型默认关闭思考（更快）。设 0 让它继续思考。
TUTU_DISABLE_THINKING=1

# 可选：response_format=json_object。Ollama 上 Qwen3 与该模式冲突，会产空字符串。
# 默认关闭；只在你确定本地 server + 模型组合支持时设 1。
TUTU_JSON_MODE=0

# 可选：打印每次 LLM 调用前后各一行摘要（→ 询问中 / ← 决策结果）。
TUTU_DEBUG_LLM=1

# 可选：打印完整 prompt 和 raw response（调 prompt 工程时用，平时太啰嗦）。
TUTU_DEBUG_VERBOSE=0

# 可选：仿真节奏，毫秒（前端 tick 间隔）。本地模型慢可调到 4000-8000；UI 上还能再叠 0.25-4× 速度档。
NEXT_PUBLIC_TICK_INTERVAL_MS=2500
