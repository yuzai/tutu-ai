# OpenAI 兼容端口 — 用任何兼容协议的提供方（OpenAI 官方、Ollama、LM Studio、vLLM、DeepSeek、Moonshot...）
# 本地 Ollama:  OPENAI_BASE_URL=http://localhost:11434/v1
# 本地 LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1
# OpenAI 官方:  OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b-instruct

# 可选：决策调用的最大 token 数（角色思考输出，不需要太长）
TUTU_MAX_TOKENS=600

# 可选：Qwen3 等带思考模式的模型默认关闭思考（更快）。设 0 让它继续思考。
TUTU_DISABLE_THINKING=1

# 可选：仿真节奏，毫秒（前端 tick 间隔）
NEXT_PUBLIC_TICK_INTERVAL_MS=1500
