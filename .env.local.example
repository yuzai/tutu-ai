# ─────────────────────────────────────────────────────────────
# LLM 后端：任何 OpenAI 兼容协议的提供方都可以
# ─────────────────────────────────────────────────────────────

# 本地 Ollama（默认）
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:3b-instruct

# ─── 远端 API 示例（取消注释替换上面三行）───────────────────────
# DeepSeek（推荐：便宜、稳、不思考）
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=deepseek-chat
#
# OpenAI 官方
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
#
# Moonshot（月之暗面 Kimi）
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=moonshot-v1-8k
#
# 通义千问 OpenAI 兼容模式
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=qwen-turbo

# ─────────────────────────────────────────────────────────────
# 调优
# ─────────────────────────────────────────────────────────────

# 决策调用的最大 token 数（被截断会报 finish=length）
TUTU_MAX_TOKENS=600

# Qwen3 等思考模型默认关闭思考（更快）。非思考模型（qwen2.5/deepseek-chat/gpt-4o-mini）设 0 即可。
TUTU_DISABLE_THINKING=0

# response_format=json_object。远端 API（DeepSeek/OpenAI/Moonshot）建议设 1 提升 JSON 稳定性。
# Ollama 上 Qwen3 思考模型与此模式冲突，本地用 Qwen3 时保持 0。
TUTU_JSON_MODE=0

# 打印每次 LLM 调用的摘要到 Next 终端
TUTU_DEBUG_LLM=1

# 打印完整 prompt + raw response（调 prompt 时用，平时关）
TUTU_DEBUG_VERBOSE=0

# 仿真节奏，毫秒（前端 tick 间隔）。本地模型慢可调到 4000-8000；远端可以 1000-2000。
NEXT_PUBLIC_TICK_INTERVAL_MS=2500

# 初始场景：tutu / office / school / playground / gym / festival / wuxia / xianxia
NEXT_PUBLIC_SCENARIO=tutu

# 同时并发的 LLM 决策上限。本地 Ollama 单 GPU 建议 2-5；远端 API 可拉到 10-20。
NEXT_PUBLIC_MAX_CONCURRENT=4
